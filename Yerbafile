rules:
  - files: "data/**/event.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

      - delete:
          path: "date_precision"
          condition: '.date_precision == "day"'

      - sort_keys:
          order:
            - id
            - title
            - location
            - kind
            - frequency
            - description
            - published_at
            - announced_on
            - start_date
            - end_date
            - year
            - date_precision
            - channel_id
            - playlist
            - status
            - last_edition
            - hybrid
            - website
            - original_website
            - tickets_url
            - meetup
            - twitter
            - mastodon
            - youtube
            - github
            - luma
            - venue
            - banner_background
            - featured_background
            - featured_color
            - coordinates
            - aliases

  - files: "data/**/involvements.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

      - quote_style:
          path: "[].users"
          value_style: plain

      - quote_style:
          path: "[].organisations"
          value_style: plain

  - files: "data/topics.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/**/cfp.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/featured_cities.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/**/sponsors.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/**/venue.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/**/schedule.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

  - files: "data/**/series.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

      - quote_style:
          path: "aliases[]"
          value_style: plain

  - files: "data/**/videos.yml"
    pipeline:
      - quote_style:
          path: "[].speakers"
          value_style: plain

      - quote_style:
          path: "[].talks[].speakers"
          value_style: plain

      - quote_style:
          path: "[].alternative_recordings[].speakers"
          value_style: plain

      - quote_style:
          path: "[].talks[].alternative_recordings[].speakers"
          value_style: plain

      - blank_lines:
          count: 1

      - sort_keys:
          path: "[]"
          order:
            - id
            - title
            - raw_title
            - original_title
            - slug
            - location
            - kind
            - event_name
            - date
            - time
            - published_at
            - announced_at
            - status
            - language
            - track
            - slides_url
            - video_provider
            - video_id
            - external_player
            - external_player_url
            - thumbnail_xs
            - thumbnail_sm
            - thumbnail_md
            - thumbnail_lg
            - thumbnail_xl
            - thumbnail_classes
            - description
            - speakers
            - talks
            - additional_resources
            - alternative_recordings

  - files: "data/speakers.yml"
    pipeline:
      - quote_style:
          key_style: plain
          value_style: double

      - sort_keys:
          path: ""
          order:
            - name
            - slug
            - github
            - twitter
            - mastodon
            - bluesky
            - linkedin
            - website
            - speakerdeck
            - aliases

      - sort:
          by: name
