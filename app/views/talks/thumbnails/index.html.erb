<% content_for :title, "Thumbnail Debug" %>

<div class="container my-8 flex flex-col gap-6" data-controller="thumbnail-batch">
  <div class="flex flex-col gap-3">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <h1 class="text-2xl font-bold">Thumbnail Debug</h1>
      <button data-action="thumbnail-batch#regenerateAll" class="btn btn-sm btn-outline gap-2">
        <%= fa("rotate", size: :sm) %> Regenerate all
      </button>
    </div>

    <p class="text-sm text-gray-500">
      Tiles generate on demand as they scroll into view (max 3 at a time) and swap in once ready — no page reload.
      PNGs are written to <code>tmp/thumbnails/generated/:event_slug/:talk_slug.png</code>.
    </p>

    <div class="flex items-center gap-2">
      <span class="text-sm text-gray-500">Variant:</span>
      <% ["both", *Talk::ThumbnailGenerator::VARIANTS].each do |v| %>
        <%= link_to v.titleize, debug_thumbnails_path(event: params[:event], variant: v),
              class: class_names("btn btn-xs", "btn-primary": @variant == v, "btn-ghost": @variant != v) %>
      <% end %>
    </div>

    <%= form_with url: debug_thumbnails_path, method: :get, class: "flex items-center gap-2" do |f| %>
      <%= f.hidden_field :variant, value: @variant %>
      <%= f.text_field :event, value: params[:event], placeholder: "filter by event slug…", class: "input input-bordered input-sm w-72" %>
      <%= f.submit "Filter", class: "btn btn-sm btn-primary" %>

      <% if params[:event].present? %>
        <%= link_to "Clear", debug_thumbnails_path(variant: @variant), class: "btn btn-sm btn-ghost" %>
      <% end %>

      <span class="text-sm text-gray-500 ml-2"><%= number_with_delimiter(@total) %> talks · page <%= @page %></span>
    <% end %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @talks.each do |talk| %>
      <div class="flex flex-col gap-2">
        <% @variants.each do |v| %>
          <div
            data-controller="thumbnail"
            data-thumbnail-url-value="<%= talk_thumbnail_path(talk, variant: v) %>"
            class="group relative aspect-video border rounded-lg overflow-hidden bg-gray-100">

            <% if @variants.size > 1 %>
              <span class="absolute top-1 left-1 z-20 text-[10px] uppercase tracking-wide bg-black/60 text-white px-1.5 py-0.5 rounded"><%= v %></span>
            <% end %>

            <div data-thumbnail-target="spinner" class="absolute inset-0 flex items-center justify-center text-gray-400">
              <span class="loading loading-spinner loading-md"></span>
            </div>

            <div data-thumbnail-target="error" hidden class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-sm text-error">
              <span>Failed to generate</span>
              <button data-action="thumbnail#regenerate" class="btn btn-xs">Retry</button>
            </div>

            <img
              data-thumbnail-target="image"
              hidden
              alt="<%= talk.title %> (<%= v %>)"
              width="1280"
              height="720"
              class="w-full h-full object-cover">

            <div class="absolute top-1 right-1 z-20 hidden group-data-[state=done]:flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <button data-action="thumbnail#regenerate" title="Regenerate" class="btn btn-xs btn-circle bg-black/60 border-0 text-white">
                <%= fa("rotate", size: :sm) %>
              </button>

              <a href="<%= talk_thumbnail_path(talk, variant: v) %>" target="_blank" rel="noopener" title="Open full size" class="btn btn-xs btn-circle bg-black/60 border-0 text-white">
                <%= fa("up-right-from-square", size: :sm) %>
              </a>
            </div>
          </div>
        <% end %>

        <div class="flex flex-col">
          <%= link_to talk.title, talk_path(talk), class: "text-sm font-medium truncate hover:text-primary" %>
          <span class="text-xs text-gray-400 truncate"><%= talk.event&.slug %> · <%= talk.slug %></span>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-between">
    <% if @page > 1 %>
      <%= link_to "← Previous", debug_thumbnails_path(event: params[:event], variant: @variant, page: @page - 1), class: "btn btn-sm" %>
    <% else %>
      <span></span>
    <% end %>

    <% if @has_next %>
      <%= link_to "Next →", debug_thumbnails_path(event: params[:event], variant: @variant, page: @page + 1), class: "btn btn-sm" %>
    <% end %>
  </div>
</div>
