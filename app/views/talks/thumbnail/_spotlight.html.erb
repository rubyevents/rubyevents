<% if speakers.size > 1 %>
  <%= render "talks/thumbnail/card", local_assigns %>
<% else %>
  <% primary_speaker = speakers.first %>
  <% subtitle = [location, formatted_date].select(&:present?).join("  •  ") %>
  <% text_shadow = (featured_background[:type] == :image) ? "text-shadow: 0 2px 8px rgba(0,0,0,0.35);" : "" %>

  <div style="position: relative; width: <%= width %>px; height: <%= height %>px; overflow: hidden; color: <%= featured_color %>; <%= bg_style %>">
    <div style="position: relative; width: 100%; height: 100%; display: flex; align-items: stretch; gap: 48px; padding: 56px 64px;">
      <div style="display: flex; flex-direction: column; flex: 1; min-width: 0;">
        <div style="display: flex; align-items: center; gap: 24px;">
          <% if event_logo_uri.present? %>
            <img src="<%= event_logo_uri %>" alt="" style="width: 88px; height: 88px; border-radius: 20px; object-fit: cover; box-shadow: 0 4px 16px rgba(0,0,0,0.35);">
          <% end %>

          <div style="display: flex; flex-direction: column; gap: 6px; min-width: 0;">
            <div style="color: <%= featured_color %>; font-size: 34px; font-weight: 800; line-height: 1.1; <%= text_shadow %>"><%= event_name %></div>

            <% if subtitle.present? %>
              <div style="color: <%= featured_color %>; font-size: 24px; font-weight: 600; opacity: 0.8; <%= text_shadow %>"><%= subtitle %></div>
            <% end %>
          </div>
        </div>

        <div style="display: flex; flex: 1; align-items: center;">
          <div style="
            color: <%= featured_color %>;
            font-size: 62px;
            font-weight: 900;
            line-height: 1.15;
            letter-spacing: -1px;
            padding-bottom: 8px;
            <%= text_shadow %>
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
          "><%= talk.title %></div>
        </div>

        <% if primary_speaker %>
          <div style="display: flex; flex-direction: column; gap: 2px; min-width: 0;">
            <div style="color: <%= featured_color %>; font-size: 40px; font-weight: 700; line-height: 1.2; <%= text_shadow %>"><%= primary_speaker[:name] %></div>

            <% if primary_speaker[:github].present? %>
              <div style="color: <%= featured_color %>; font-size: 30px; font-weight: 600; opacity: 0.7; <%= text_shadow %>">@<%= primary_speaker[:github] %></div>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if primary_speaker %>
        <div style="display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 380px;">
          <img src="<%= primary_speaker[:avatar_url] %>" alt="<%= primary_speaker[:name] %>" style="width: 380px; height: 380px; border-radius: 9999px; object-fit: cover; border: 10px solid <%= featured_color %>; box-shadow: 0 10px 30px rgba(0,0,0,0.45);">
        </div>
      <% end %>
    </div>
  </div>
<% end %>
