<div class="container py-8 hotwire-native:py-3" data-controller="events-view-switcher">
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between w-full gap-4 hotwire-native:hidden">
    <h1 class="title shrink-0">
      <%= title "Meetups" %>
    </h1>

    <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
      <div class="tabs tabs-boxed">
        <button type="button" class="tab tab-active" data-events-view-switcher-target="previewButton" data-action="click->events-view-switcher#showPreview">
          Preview
        </button>

        <button type="button" class="tab" data-events-view-switcher-target="listButton" data-action="click->events-view-switcher#showList">
          List
        </button>
      </div>
      <div class="flex gap-4 whitespace-nowrap">
        <%= link_to "Upcoming Events", events_path, class: "link" %>
      </div>
    </div>
  </div>

  <div data-events-view-switcher-target="previewView">
    <%= render partial: "events/featured_card_list", locals: {events: @meetups} %>
  </div>

  <div class="hidden mt-6" data-events-view-switcher-target="listView">
    <%= render partial: "events/plain_list", locals: {events: @meetups} %>
  </div>

  <div class="mt-6">
    <h1>Browse worldwide meetups</h1>
    <p>
      Explore Ruby meetups from around the world, or find all events by
      <%= link_to "continent", continents_path, class: "link" %>,
      <%= link_to "country", countries_path, class: "link" %>
      or
      <%= link_to "city", cities_path, class: "link" %>.
    </p>

    <% @countries_by_continent.each do |continent, countries| %>
      <% if countries.any? %>
        <h2 class="mt-3"><%= link_to continent.name, continent_path(continent), class: "hover:underline" %></h2>

        <div
          id="events-<%= continent.name %>"
          class="
            grid sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-x-8 lg:gap-x-12 gap-y-2
            min-w-full pt-4 pb-8
          ">
          <% countries.sort_by(&:iso_short_name).each do |country| %>
            <% events = @events_by_country[country] %>
            <% next if events.nil? %>

            <%= link_to location_meetups_path(country), id: "country-#{country.alpha2}", class: "event flex justify-between items-center" do %>
              <div class="flex items-center gap-2">
                <span class="event-name"><%= country.emoji_flag %>
                  <%= country.name %></span>
              </div>
              <div class="flex gap-2 items-center">
                <%= ui_badge(
                      events.count,
                      kind: :secondary,
                      outline: true,
                      size: :lg,
                      class: "min-w-10"
                    ) %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-8 mt-6 hotwire-native:hidden">
    <div class="flex items-start">
      <%= fa("question-circle", size: :sm, class: "fill-amber-600 mt-0.5 mr-3 flex-shrink-0") %>
      <div>
        <h3 class="font-semibold text-amber-800 mb-1">Meetup data is incomplete</h3>
        <p class="text-sm text-amber-700 mb-2">
          We are looking for more meetups to add to the database. If you know of a Ruby meetup that is not listed, please let us know by <%= link_to "creating an issue", "https://github.com/rubyevents/rubyevents/issues/new", class: "link", target: "_blank", rel: "noopener" %> or contributing the data.
        </p>
      <%= link_to "Documentation on adding a meetup", "https://github.com/rubyevents/rubyevents/blob/main/docs/ADDING_MEETUPS.md", class: "text-sm font-medium text-amber-800 underline hover:text-amber-900", target: "_blank", rel: "noopener" %>
      </div>
    </div>
  </div>
</div>
