      <%= turbo_frame_tag "browse-talk-kinds", src: browse_path("talk_kinds"), loading: :lazy do %>
        <%= render "browse/pill_row_skeleton", min_height: "140px" %>
      <% end %>

      <%= turbo_frame_tag "browse-talk-languages", src: browse_path("talk_languages"), loading: :lazy do %>
