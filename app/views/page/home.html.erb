<% title hotwire_native_app? ? "RubyEvents" : "RubyEvents.org - On a mission to index all Ruby events" %>
<% set_meta_tags site: nil # remove the "... | RubyEvents.org" from the title as that's already included above %>
<% content_for :body_class, "home-page" %>

<% if @featured_events.any? %>
  <% content_for :head do %>
    <meta name="theme-color" content="<%= @featured_events.first.featured_background %>" data-featured-theme-color>

    <style>
      :root {
        --featured-color: <%= @featured_events.first.featured_color %>;
        --featured-background: <%= @featured_events.first.featured_background %>;
      }

      body.home-page .navbar {
        background: var(--featured-background);
      }

      body.home-page .navbar .desktop-menu a,
      body.home-page .navbar > .container a:not(.dropdown-content a) {
        color: var(--featured-color);
      }

      body.home-page .navbar .dropdown-content a,
      body.home-page .navbar .dropdown-content button {
        color: #000 !important;
      }

      body.home-page .navbar .btn-primary {
        background-color: white;
        color: black !important;
        border: 1px solid rgb(156 163 175 / var(--tw-border-opacity, 1));
      }

      body.home-page .navbar .btn-primary:hover {
        background-color: rgba(255, 255, 255, 0.9);
      }

      body.home-page .navbar svg {
        fill: var(--featured-color);
      }

      .splide__track, .splide__list {
        background: transparent !important;
      }
      body.home-page .splide {
        background: var(--featured-background);
        padding-bottom: 3rem;
        margin-bottom: 3rem !important;
        border-bottom: 1px solid rgba(0, 0, 0, 0.2);
      }

      <% if @featured_events.size > 1 && false %>
        @media (min-width: 1024px) {
          body.home-page .splide {
            padding-bottom: 0;
          }
        }
      <% end %>
      body.home-page .featured-stats {
        color: var(--featured-color);
      }
    </style>
  <% end %>
<% end %>

<main class="hotwire-native:mt-6">
  <% cache @featured_events do %>
    <% if @featured_events.any? %>
      <section class="splide w-full" aria-label="Featured Events" data-controller="splide">
        <div class="featured-stats w-full pt-8 lg:shrink-0">
          <div class="container hotwire-native:hidden flex flex-col items-center text-center">
            <h2 class="text-2xl font-bold tracking-tight mb-6">On a mission to index all Ruby events</h2>
            <div class="flex flex-wrap gap-4 justify-center items-center text-sm">
              <div class="flex flex-wrap justify-center items-center gap-2 mb-12 lg:mb-6">
                <span class="opacity-80">We have indexed</span>

                <%= link_to events_path, class: "inline-flex items-center px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm font-semibold border hover:bg-white/30 transition-colors", style: "border-color: color-mix(in srgb, var(--featured-color) 25%, transparent);" do %>
                  <%= @events_count %> events
                <% end %>

                <span class="opacity-80">and</span>

                <%= link_to talks_path, class: "inline-flex items-center px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm font-semibold border hover:bg-white/30 transition-colors", style: "border-color: color-mix(in srgb, var(--featured-color) 25%, transparent);" do %>
                  <%= @talks_count %> talks
                <% end %>

                <span class="opacity-80">from</span>

                <%= link_to speakers_path, class: "inline-flex items-center px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm font-semibold border hover:bg-white/30 transition-colors", style: "border-color: color-mix(in srgb, var(--featured-color) 25%, transparent);" do %>
                  <%= @speakers_count %> speakers
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <div class="splide__track lg:flex-1 lg:flex lg:flex-col lg:justify-center lg:min-h-0">
          <ul class="splide__list">
            <% @featured_events.each_with_index do |event, index| %>
              <li
                class="splide__slide"
                data-featured-color="<%= event.featured_color %>"
                data-featured-background="<%= event.featured_background %>">
                <div class="<%= "hidden" if Current.user || index != 0 %>">
                  <%= render partial: "events/featured_home", locals: {event: event} %>
                </div>
              </li>
            <% end %>
          </ul>
        </div>

        <a href="#more-content" class="hidden lg:flex lg:shrink-0 justify-center pb-1" aria-label="Scroll for more" style="color: var(--featured-color);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>

        <% if @featured_events.size > 1 %>
          <div class="hidden lg:flex lg:shrink-0 justify-center items-center gap-2 py-4" style="color: var(--featured-color);">
            <% @featured_events.each_with_index do |_featured_event, index| %>
              <button
                type="button"
                class="h-2 w-2 rounded-full bg-current transition-opacity <%= index.zero? ? "opacity-100" : "opacity-40" %>"
                data-slide-dot
                data-index="<%= index %>"
                data-action="click->splide#goTo"
                aria-label="Go to slide <%= index + 1 %>"></button>
            <% end %>
          </div>
        <% end %>

        <% if @featured_events.size > 1 && false %>
          <div class="hidden lg:grid lg:shrink-0 grid-cols-3 gap-px w-full border-t" style="border-color: color-mix(in srgb, var(--featured-color) 35%, transparent); background: color-mix(in srgb, var(--featured-color) 35%, transparent);">
            <% @featured_events.each_with_index do |upcoming_event, index| %>
              <% upcoming_color = upcoming_event.static_metadata.featured_color %>
              <% upcoming_background = upcoming_event.static_metadata.featured_background %>
              <% card_style = "color: #{upcoming_color};" %>
              <% card_style += upcoming_background.to_s.start_with?("data:") ? " background: url('#{upcoming_background}'); background-size: cover; background-position: center;" : " background: #{upcoming_background};" %>

              <%= link_to featured_cta_path(upcoming_event),
                    class: "flex items-center gap-3 p-4 w-full overflow-hidden hover:brightness-125 transition #{"hidden" unless index.between?(1, 3)}",
                    style: card_style,
                    data: {up_next_card: ""} do %>
                <div class="shrink-0 w-16 h-12 flex items-center justify-center">
                  <%= image_tag upcoming_event.featured_image_path, class: "max-h-12 max-w-full object-contain", loading: "lazy", alt: upcoming_event.name %>
                </div>

                <div class="min-w-0 flex-1">
                  <div class="font-semibold text-sm truncate"><%= upcoming_event.name %></div>
                  <div class="text-xs opacity-70 truncate"><%= upcoming_event.formatted_dates %></div>
                </div>

                <%= render "events/featured_badge", event: upcoming_event, extra_class: "shrink-0" %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  <% end %>

  <div class="container" id="more-content" style="scroll-margin-top: 5rem;">
    <div class="flex flex-col gap-12 mt-12">
      <%= turbo_frame_tag "browse-newest-talks", src: browse_path("newest_talks"), loading: :lazy do %>
        <%= render "browse/content_row_skeleton" %>
      <% end %>

      <%= turbo_frame_tag "browse-closing-cfps", src: browse_path("closing_cfps"), loading: :lazy do %>
        <%= render "browse/event_row_skeleton", min_height: "174px", card_height: "h-24" %>
      <% end %>

      <%= turbo_frame_tag "browse-recently-published", src: browse_path("recently_published"), loading: :lazy do %>
