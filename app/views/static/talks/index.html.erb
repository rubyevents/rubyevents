<div class="container mx-auto px-4 py-8 max-w-6xl">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold">Edit Talks</h1>
      <p class="text-gray-500 mt-1">
        <%= link_to @static_event.title, event_path(@static_event.slug), class: "link link-hover" %>
        &mdash; <%= @talks.count %> talks
      </p>
    </div>
    <%= ui_button "Add Talk", url: new_static_event_talk_path(@static_event.slug), kind: :primary, size: :sm %>
  </div>

  <% if @talks.empty? %>
    <div class="text-center py-12 text-gray-400">
      No talks yet. Add one to get started.
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr>
            <th>Title</th>
            <th>Speakers</th>
            <th>Provider</th>
            <th>Date</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @talks.each do |talk| %>
            <tr>
              <td class="max-w-xs truncate font-medium"><%= talk.title %></td>
              <td class="text-sm text-gray-500"><%= Array(talk["speakers"]).join(", ") %></td>
              <td class="text-sm"><%= talk.video_provider %></td>
              <td class="text-sm"><%= talk.date %></td>
              <td class="text-right">
                <div class="flex justify-end gap-2">
                  <%= ui_button url: edit_static_event_talk_path(@static_event.slug, talk.id), kind: :ghost, size: :sm do %>
                    <%= fa "pen-to-square", size: :sm %>
                  <% end %>
                  <%= ui_button url: static_event_talk_path(@static_event.slug, talk.id), method: :delete, kind: :ghost, size: :sm, data: { turbo_confirm: "Delete '#{talk.title}'?" } do %>
                    <%= fa "trash", size: :sm, class: "text-error" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
