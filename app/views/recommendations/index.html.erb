<%= render layout: "shared/library_layout" do %>
  <h1 class="title text-primary hotwire-native:hidden">
    <%= title "For You" %>
  </h1>

  <% if @recommended_talks.present? %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
      <% @recommended_talks.each do |talk| %>
        <div>
          <%= render "talks/card_thumbnail", talk: talk, back_to: recommendations_path, back_to_title: "For You" %>
        </div>
      <% end %>
    </div>

    <div class="flex w-full mt-4">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="max-w-md mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">No recommendations yet</h2>
        <p class="text-gray-600 mb-6">
          Watch some talks to get personalized recommendations based on your interests and viewing history.
        </p>
        <%= link_to talks_path, class: "btn btn-primary" do %>
          <%= fa("video", size: :sm, class: "mr-2") %>
          Browse Talks
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
