<% redirect_to_path = params.delete(:redirect_to) || request.url %>

<div class="flex items-center justify-center sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <div class="mt-4 leading-relaxed"><strong>Sign in</strong> to bookmark talks, create watch lists, mark your speaker page as verified and more to come.</div>
    </div>
    <div class="mt-8 space-y-6">
      <%= render "sessions/oauth_buttons", redirect_to_path: redirect_to_path, state: @state %>
      <div class="text-base font-light leading-relaxed"> We collect your email address associated to your GitHub account and name to create your account. All emails are encrypted in our database. We do not share your email address with anyone else.</div>
    </div>
  </div>
</div>
