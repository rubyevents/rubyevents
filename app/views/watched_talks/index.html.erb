<%= render layout: "shared/library_layout" do %>
  <h1 class="title text-primary hotwire-native:hidden">
    <%= title((@filter == "in_progress") ? "Continue Watching" : "Watch History") %>
  </h1>

  <% if @filter == "in_progress" %>
    <% if @in_progress_talks.any? %>
      <div class="flex flex-col gap-2">
        <% @in_progress_talks.each do |watched_talk| %>
          <%= render partial: "talks/card_horizontal",
                locals: {
                  talk: watched_talk.talk,
                  watched_talk: watched_talk,
                  user_watched_talks: user_watched_talks,
                  show_event_name: true,
                  tooltip: false
                } %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="max-w-md mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Nothing in progress</h2>
          <p class="text-gray-600 mb-6">Start watching a talk and it will appear here so you can pick up where you left off.</p>
          <%= link_to talks_path, class: "btn btn-primary" do %>
            <%= fa("video", size: :sm, class: "mr-2") %>
            Browse Talks
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <% if @in_progress_talks.any? %>
      <%= link_to watched_talks_path(filter: "in_progress"), class: "flex items-center justify-between p-4 rounded-xl bg-white border border-base-300 hover:border-primary hover:shadow-md transition-all" do %>
        <div class="flex items-center gap-3">
          <%= fa("play", size: :lg, class: "fill-primary") %>

          <div>
            <div class="font-semibold">Continue Watching</div>
            <div class="text-sm text-gray-500"><%= pluralize(@in_progress_talks.size, "talk") %> in progress</div>
          </div>
        </div>
        <%= fa("arrow-right-long", size: :sm, class: "fill-gray-400") %>
      <% end %>
    <% end %>

    <% if @watched_talks_by_date.present? %>
      <div id="talks" class="flex flex-col gap-8">
        <% @watched_talks_by_date.each do |date, watched_talks| %>
          <div class="flex flex-col gap-3">
            <h2 class="text-lg font-bold text-gray-900">
              <% if date == Date.current %>
                Today
              <% elsif date == Date.current - 1 %>
                Yesterday
              <% else %>
                <%= date.strftime("%B %-d, %Y") %>
              <% end %>
            </h2>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
              <% watched_talks.each do |watched_talk| %>
                <div>
                  <%= render partial: "talks/card_thumbnail",
                        locals: {
                          talk: watched_talk.talk,
                          watched_talk: watched_talk,
                          back_to: watched_talks_path,
                          back_to_title: "Watch History"
                        } %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @in_progress_talks.empty? && @watched_talks_by_date.blank? %>
      <div class="text-center py-12">
        <div class="max-w-md mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">No watched videos yet</h2>
          <p class="text-gray-600 mb-6">
            Start watching talks to track your viewing history and pick up where you left off.
          </p>

          <%= link_to talks_path, class: "btn btn-primary" do %>
            <%= fa("video", size: :sm, class: "mr-2") %>
            Browse Talks
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
