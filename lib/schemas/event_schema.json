      "type": "string",
      "description": "CSS background value for the banner (color or gradient)"
    },
    "featured_background": {
      "type": "string",
      "description": "CSS background color for featured cards"
    },
    "featured_color": {
      "type": "string",
      "description": "CSS text color for featured cards"
    },
    "coordinates": {
      "description": "Geographic coordinates (use 'coordinates: false' for online events)",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "latitude": {
              "type": "number",
              "description": "Latitude coordinate"
            },
            "longitude": {
              "type": "number",
              "description": "Longitude coordinate"
            }
          },
          "required": [
            "latitude",
            "longitude"
          ],
          "additionalProperties": false
        },
        {
          "type": "boolean"
        }
      ]
    }
