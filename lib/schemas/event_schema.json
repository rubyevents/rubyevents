      "type": "array",
      "description": "YouTube channels associated with this event",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "YouTube channel ID (starts with UC...)"
          },
          "name": {
            "type": "string",
            "description": "YouTube channel display name"
          },
