{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the event (YouTube playlist ID or custom slug)"
    },
    "title": {
      "type": "string",
      "description": "Full name of the event (e.g., 'RailsConf 2024')"
    },
    "description": {
      "type": "string",
      "description": "Description of the event"
    },
    "aliases": {
      "type": "array",
      "description": "Alternative names for the event",
      "items": {
        "type": "string"
      }
    },
    "kind": {
      "type": "string",
      "enum": [
        "conference",
        "meetup",
        "retreat",
        "hackathon",
        "event",
        "workshop"
      ],
      "description": "Type of event"
    },
    "hybrid": {
      "type": "boolean",
      "description": "Whether the event has both in-person and online attendance"
    },
    "status": {
      "type": "string",
      "enum": [
        "cancelled",
        "postponed",
        "scheduled"
      ],
      "description": "Event status"
    },
    "last_edition": {
      "type": "boolean",
      "description": "Whether this is the last edition of the event"
    },
    "start_date": {
      "type": "string",
      "description": "Start date of the event (YYYY-MM-DD format)"
    },
    "end_date": {
      "type": "string",
      "description": "End date of the event (YYYY-MM-DD format)"
    },
    "published_at": {
      "type": "string",
      "description": "Date when videos were published (YYYY-MM-DD format)"
    },
    "announced_on": {
      "type": "string",
      "description": "Date when the event was announced (YYYY-MM-DD format)"
    },
    "year": {
      "type": "integer",
      "description": "Year of the event"
    },
    "date_precision": {
      "type": "string",
      "enum": [
        "year",
        "month",
        "day"
      ],
      "description": "Precision of the date (when exact dates are unknown)"
    },
    "frequency": {
      "type": "string",
      "description": "How often the event occurs (for recurring meetups)"
    },
    "location": {
      "type": "string",
      "description": "Location in 'City, Country' format (e.g., 'Detroit, MI' or 'Tokyo, Japan')"
