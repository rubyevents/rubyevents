      "type": "string",
      "description": "Vimeo channel URL"
    },
    "youtube_channels": {
      "type": "array",
      "description": "YouTube channels associated with this series",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "YouTube channel ID (starts with UC...)"
          },
          "name": {
            "type": "string",
            "description": "YouTube channel display name"
          },
          "handle": {
            "type": "string",
            "description": "YouTube channel handle (e.g. @HelveticRuby)"
          },
          "playlist_matcher": {
            "type": "string",
            "description": "Pattern to match playlists on this channel"
          }
        },
        "required": [
          "id",
          "name",
          "handle"
        ],
        "additionalProperties": false
      }
    },
    "aliases": {
      "type": "array",
      "description": "Alternative names for the series",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false,
  "strict": true
