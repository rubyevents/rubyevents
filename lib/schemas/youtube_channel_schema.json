{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "YouTube channel ID (starts with UC...)"
    },
    "name": {
      "type": "string",
      "description": "YouTube channel display name"
    },
    "handle": {
      "type": "string",
      "description": "YouTube channel handle (e.g. @HelveticRuby)"
    },
    "playlist_matcher": {
      "type": "string",
      "description": "Pattern to match playlists on this channel"
    }
  },
  "required": [
    "id",
    "name",
    "handle"
  ],
  "additionalProperties": false,
  "strict": true
}