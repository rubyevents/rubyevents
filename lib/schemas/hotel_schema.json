{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Hotel name"
    },
    "kind": {
      "type": "string",
      "description": "Type of hotel (e.g., 'Speaker Hotel')"
    },
    "description": {
      "type": "string",
      "description": "Hotel description"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City name"
        },
        "region": {
          "type": "string",
          "description": "State/Province/Region"
        },
        "postal_code": {
          "type": "string",
          "description": "Postal/ZIP code"
        },
        "country": {
          "type": "string",
          "description": "Country name"
        },
        "country_code": {
          "type": "string",
          "description": "ISO country code (e.g., 'US', 'CA', 'JP')"
        },
        "display": {
          "type": "string",
          "description": "Full formatted address for display"
        }
      },
      "required": [
        "street",
        "city",
        "country",
        "country_code",
        "display"
      ],
      "additionalProperties": false,
      "description": "Hotel address"
    },
    "url": {
      "type": "string",
      "description": "Hotel website URL"
    },
    "distance": {
      "type": "string",
      "description": "Distance from venue"
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "latitude": {
          "type": "number",
          "description": "Latitude coordinate"
        },
        "longitude": {
          "type": "number",
          "description": "Longitude coordinate"
        }
      },
      "required": [
        "latitude",
        "longitude"
      ],
      "additionalProperties": false
    },
    "maps": {
      "type": "object",
      "properties": {
        "google": {
          "type": "string",
          "description": "Google Maps URL"
        },
        "apple": {
          "type": "string",
          "description": "Apple Maps URL"
        },
        "openstreetmap": {
          "type": "string",
          "description": "OpenStreetMap URL"
        }
      },
      "required": [],
      "additionalProperties": false
    }
  },
  "required": [
    "name",
    "address",
    "coordinates"
  ],
  "additionalProperties": false,
  "strict": true
}