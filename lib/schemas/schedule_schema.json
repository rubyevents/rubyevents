{
  "type": "object",
  "properties": {
    "days": {
      "type": "array",
      "description": "List of conference days",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the day (e.g., 'Day 1', 'Workshop Day')"
          },
          "date": {
            "type": "string",
            "description": "Date of the day (YYYY-MM-DD format)"
          },
          "grid": {
            "type": "array",
            "description": "Time slots for the day",
            "items": {
              "type": "object",
              "properties": {
                "start_time": {
                  "type": "string",
                  "description": "Start time (HH:MM format)"
                },
                "end_time": {
                  "type": "string",
                  "description": "End time (HH:MM format)"
                },
                "slots": {
                  "type": "integer",
                  "description": "Number of parallel tracks/slots"
                },
                "description": {
                  "type": "string",
                  "description": "Description of the time slot"
                },
                "items": {
                  "type": "array",
                  "description": "Items in this time slot",
                  "items": {
                    "anyOf": [
                      {
                        "type": "string",
                        "description": "Simple item name (e.g., 'Lunch', 'Break')"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "title": {
                            "type": "string",
                            "description": "Title of the session"
                          },
                          "description": {
                            "type": "string",
                            "description": "Description of the session"
                          },
                          "speakers": {
                            "type": "array",
                            "description": "List of speaker names",
                            "items": {
                              "type": "string"
                            }
                          },
                          "track": {
                            "type": "string",
                            "description": "Track name"
                          },
                          "room": {
                            "type": "string",
                            "description": "Room name/number"
                          }
                        },
                        "required": [
                          "title"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                }
              },
              "required": [
                "start_time",
                "end_time"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "name",
          "date"
        ],
        "additionalProperties": false
      }
    },
    "tracks": {
      "type": "array",
      "description": "Track definitions for the schedule",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Track name"
          },
          "color": {
            "type": "string",
            "description": "Track color (hex)"
          },
          "text_color": {
            "type": "string",
            "description": "Text color for the track (hex)"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "days"
  ],
  "additionalProperties": false,
  "strict": true
}